{
  "name": "backend-iluminacion-hernandez",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.1",
  "type": "module",
  "description": "API Express con TypeScript y Clean Architecture",
  "main": "dist/infrastructure/server.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/infrastructure/server.js",
    "dev": "tsx watch src/infrastructure/server.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "docker:db:up": "docker compose up -d db",
    "docker:db:down": "docker compose down",
    "docker:db:logs": "docker compose logs -f db"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1024.0",
    "better-auth": "^1.5.6",
    "compression": "^1.7.5",
    "cors": "^2.8.5",
    "dotenv": "^17.4.0",
    "drizzle-orm": "^0.45.2",
    "express": "^4.21.2",
    "express-async-errors": "^3.1.1",
    "helmet": "^8.0.0",
    "multer": "^2.1.1",
    "pg": "^8.20.0",
    "stripe": "^22.0.0"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
