# Cadena para la app (debe coincidir con POSTGRES_* si usas Docker Compose)
DATABASE_URL=postgresql://iluminacion:dev_change_me@localhost:5432/iluminacion_hernandez

# Solo para compose.yaml (postgres)
POSTGRES_USER=iluminacion
POSTGRES_PASSWORD=dev_change_me
POSTGRES_DB=iluminacion_hernandez
POSTGRES_PORT=5432
BETTER_AUTH_SECRET=genera_un_secreto_de_al_menos_32_caracteres
BETTER_AUTH_URL=http://localhost:3000
# OAuth Google: redirect autorizado en consola → {BETTER_AUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
TRUSTED_ORIGINS=http://localhost:3000,http://localhost:4200,http://localhost:4321
PORT=3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4200,http://localhost:4321

# Catálogo (Stripe + S3). Sin estas variables no se monta /api/v1/products.
STRIPE_SECRET_KEY=
STRIPE_CURRENCY=mxn
AWS_REGION=us-east-1
S3_BUCKET=
# URL pública base donde se sirven los objetos (CloudFront o endpoint público del bucket).
S3_PUBLIC_BASE_URL=
# Opcional: MinIO u otro compatible S3 (fuerza path-style).
# S3_ENDPOINT=http://localhost:9000
