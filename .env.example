# Cadena para la app (debe coincidir con POSTGRES_* si usas Docker Compose)
DATABASE_URL=postgresql://iluminacion:dev_change_me@localhost:5432/iluminacion_hernandez

# Solo para compose.yaml (postgres)
POSTGRES_USER=iluminacion
POSTGRES_PASSWORD=dev_change_me
POSTGRES_DB=iluminacion_hernandez
POSTGRES_PORT=5432
BETTER_AUTH_SECRET=genera_un_secreto_de_al_menos_32_caracteres
BETTER_AUTH_URL=http://localhost:3000
# OAuth Google: redirect autorizado en consola → {BETTER_AUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
TRUSTED_ORIGINS=http://localhost:3000,http://localhost:4200,http://localhost:4321
PORT=3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4200,http://localhost:4321

# Catálogo (Stripe + S3). Rutas en /api/v1/products (ver docs).
STRIPE_SECRET_KEY=
STRIPE_CURRENCY=mxn
# Credenciales para S3 (AWS) o MinIO: el SDK las lee del entorno por defecto.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Opcional: credenciales temporales (STS).
# AWS_SESSION_TOKEN=
AWS_REGION=us-east-1
S3_BUCKET=
# Opcional: solo si la URL pública no es la estándar (p. ej. CloudFront u otro dominio).
# S3_PUBLIC_BASE_URL=https://dxxxx.cloudfront.net
# Opcional: MinIO u otro compatible S3 (URL pública = {S3_ENDPOINT}/{S3_BUCKET}/clave).
# S3_ENDPOINT=http://localhost:9000
